# 硅基流动（与 OpenAI 兼容的 Base URL）
BASE_URL=https://api.siliconflow.cn/v1

# 必填：API Key
API_KEY=

# 向量库目录
VECTOR_DB_DIR=./vector_db

# 关系库（对话会话与消息）。留空则使用 SQLite：项目根下 ./data/app.db（与上传 PDF 同目录，已在 .gitignore）
# PostgreSQL 示例：DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/mycampus
# DATABASE_URL=

# 对话模型（须与硅基流动控制台中的模型 ID 完全一致，例如 DeepSeek / Qwen）
# DeepSeek 示例（以平台实际名称为准）：CHAT_MODEL=deepseek-ai/DeepSeek-V3.2
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 嵌入模型
EMBED_MODEL=BAAI/bge-m3

# 检索 Top-K（送入重排前，引擎会先合并更大候选池）
RAG_TOP_K=5
# 纯向量召回条数上限（越大召回越高、略慢）
RAG_VECTOR_FETCH=200
# 1 开启：向量 + 问句子串全文包含（Chroma where_document），词面命中率更高
RAG_HYBRID=1
# 混合检索最多追加几次「含子串」查询（控制延迟）
RAG_HYBRID_TERMS_MAX=5
# 1 开启：问「图书馆开放时间」等时，若能从检索块中解析出时段行，则直接返回原文、不调 LLM 改数字
RAG_VERBATIM_HOURS=1

# 分块：字符长度与重叠
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# 嵌入 API 每批条数（减少请求次数）
RAG_EMBED_BATCH=16

# 对话参数：事实类 RAG 建议 temperature=0，同一问题多次回答更一致
CHAT_TEMPERATURE=0
# 送入大模型的检索条数（重排后的前 N 条），默认 2，可减少多段矛盾导致的乱答
CHAT_RAG_LLM_K=2
# 可选：固定随机种子（若 API 支持 seed），进一步稳定输出
# CHAT_SEED=42
CHAT_MAX_TOKENS=768
CHAT_TIMEOUT=60

# 前后端分离：填写前端页面来源，英文逗号分隔（不要用 * 上生产）
# 示例：Python http.server 8080 + Vite 5174
# CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5174,http://localhost:5174

# 设为 1 时由 FastAPI 托管 frontend/dist（需先 npm run build）；默认 0 仅 API
# SERVE_FRONTEND=0
